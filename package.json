{
  "name": "screenfocus",
  "version": "1.0.0",
  "description": "A beautiful digital wellbeing and productivity tracker for Windows",
  "main": "./out/main/index.js",
  "author": "ScreenFocus",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder --win --config",
    "package:portable": "electron-vite build && electron-builder --win portable --config"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "framer-motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.screenfocus.app",
    "productName": "ScreenFocus",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "ScreenFocus",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "ScreenFocusPortable.exe"
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
